{
  "name": "premium-stock-tracker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "tsx server/server.ts",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "build": "tsc -b && vite build",
    "start": "tsx server/server.ts",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "check": "typescript && tsc --noEmit",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.90.12",
    "@trpc/client": "^11.7.2",
    "@trpc/react-query": "^11.7.2",
    "@trpc/server": "^11.7.2",
    "@vitejs/plugin-react": "^5.1.1",
    "axios": "^1.13.2",
    "cheerio": "^1.1.2",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "lucide-react": "^0.561.0",
    "mysql2": "^3.15.3",
    "puppeteer": "^25.1.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "vite": "^7.2.7",
    "wouter": "^3.7.1",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
